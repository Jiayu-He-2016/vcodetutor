# Public frontend mode. Use "mock" for the portfolio site and "local" for private local demos.
VITE_ASSISTANT_MODE=mock

# Local backend settings.
ASSISTANT_PORT=5175
ASSISTANT_HOST=127.0.0.1
ASSISTANT_CORS_ORIGIN=http://localhost:5173

# Server-only secret. Put the real key in .env.local, never in frontend code.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
